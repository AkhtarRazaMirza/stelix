{
  "name": "stelix-backend",
  "version": "1.0.0",
  "description": "this is the backend of my ai workflow service",
  "keywords": [
    "web-dev",
    "ai",
    "workflow"
  ],
  "license": "ISC",
  "author": "Akhtar Raza Mirza",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "db-start": "docker-compose up -d",
    "db-stop": "docker-compose down",
    "db-generate": "npx drizzle-kit generate",
    "db-migrate": "npx drizzle-kit migrate",
    "db-studio": "npx drizzle-kit studio"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "groq-sdk": "^1.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "resend": "^6.12.4",
    "tsc-watch": "^7.2.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4"
  }
}
